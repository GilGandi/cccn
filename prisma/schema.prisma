generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  EDITOR
}

enum Recorrencia {
  NENHUMA
  SEMANAL
  QUINZENAL
  MENSAL
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  password  String
  role      Role     @default(EDITOR)
  perfilId  String?
  perfil    Perfil?  @relation("UserPerfil", fields: [perfilId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Categoria {
  id        String   @id @default(cuid())
  nome      String
  cor       String   @default("#c8b99a")
  fotoUrl   String?
  eventos   Evento[]
  createdAt DateTime @default(now())
}

model Evento {
  id          String      @id @default(cuid())
  titulo      String
  descricao   String?
  data        DateTime
  horario     String
  categoriaId String?
  categoria   Categoria?  @relation(fields: [categoriaId], references: [id])
  destaque    Boolean     @default(false)
  recorrencia Recorrencia @default(NENHUMA)
  recorrenciaFim DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Palavra {
  id        String   @id @default(cuid())
  titulo    String
  descricao String?
  videoUrl  String?
  pregador  String?
  data      DateTime @default(now())
  publicado Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Foto {
  id        String   @id @default(cuid())
  url       String
  legenda   String?
  galeria   String   @default("geral")
  ordem     Int      @default(0)
  createdAt DateTime @default(now())
}

model Aviso {
  id        String   @id @default(cuid())
  texto     String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Playlist {
  id        String   @id @default(cuid())
  titulo    String
  url       String
  tipo      String   @default("spotify") // spotify | youtube
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Config {
  id    String @id
  valor String
}

model Lider {
  id        String   @id @default(cuid())
  nome      String
  cargo     String
  bio       String?
  fotoUrl   String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Perfis com permissões customizáveis ─────────────────────────────────────

model Perfil {
  id          String   @id @default(cuid())
  nome        String   @unique
  descricao   String?
  // Permissões como JSON: { agenda: true, avisos: false, galeria: true, ... }
  permissoes  String   @default("{}")
  sistema     Boolean  @default(false) // true = não pode ser deletado (SuperAdmin, Admin, Editor)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]   @relation("UserPerfil")
}

// ─── Participantes globais (pessoas que se inscrevem em eventos) ──────────────

model Participante {
  id          String    @id @default(cuid())
  nome        String
  telefone    String?
  sexo        String?   // M | F
  idade       Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  inscricoes  Inscricao[]
}

// ─── Eventos de inscrição (diferente da agenda) ───────────────────────────────

model EventoInscricao {
  id               String    @id @default(cuid())
  titulo           String
  descricao        String?
  fotoUrl          String?
  slug             String    @unique
  // Campos obrigatórios na inscrição
  telefoneObrig    Boolean   @default(false)
  sexoObrig        Boolean   @default(false)
  idadeObrig       Boolean   @default(false)
  // Datas (múltiplas, guardadas como JSON: ["2024-06-01", "2024-06-02"])
  datas            String    @default("[]")
  dataEncerramento DateTime
  ativo            Boolean   @default(true)
  vagas            Int?      // null = ilimitado
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  inscricoes       Inscricao[]
}

// ─── Inscrições (vínculo participante ↔ evento) ───────────────────────────────

model Inscricao {
  id               String          @id @default(cuid())
  participanteId   String
  participante     Participante    @relation(fields: [participanteId], references: [id])
  eventoId         String
  evento           EventoInscricao @relation(fields: [eventoId], references: [id])
  createdAt        DateTime        @default(now())

  @@unique([participanteId, eventoId]) // uma inscrição por pessoa por evento
}
